# clangd / Cursor: Zephyr sysbuild puts compile_commands.json under build/<image>/.
# Rebuild with CMAKE_EXPORT_COMPILE_COMMANDS=ON (NCS Connect or ./build.sh) after Kconfig/source changes.
#
# Strip GCC-only flags that host clang does not understand (avoids false "Unknown argument" on every file).
CompileFlags:
  CompilationDatabase: build/minneuro
  Remove:
    - -mfp16-format=ieee
    - -fno-reorder-functions
    - --param=min-pagesize=0
    - -specs=picolibc.specs

Index:
  Background: Build
